{
  "manifest_version": 2,
  "name": "Zotero NotebookLM Bridge",
  "version": "0.1.1",
  "description": "Prepare Zotero papers for NotebookLM import.",
  "homepage_url": "https://github.com/valeryzhu/zotero2notebookLM",
  "author": "Valery Zhu",
  "icons": {
    "48": "chrome/content/icons/icon.svg",
    "96": "chrome/content/icons/icon.svg"
