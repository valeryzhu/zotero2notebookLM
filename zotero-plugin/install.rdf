<?xml version="1.0"?>
<RDF:RDF
    xmlns:em="http://www.mozilla.org/2004/em-rdf#"
    xmlns:NC="http://home.netscape.com/NC-rdf#"
    xmlns:RDF="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
    <RDF:Description
        RDF:about="urn:mozilla:install-manifest"
        em:id="zotero2notebooklm@valeryzhu.github.io"
        em:name="Zotero NotebookLM Bridge"
        em:version="0.1.1"
        em:type="2"
        em:creator="Valery Zhu"
        em:description="Prepare Zotero papers for NotebookLM import."
        em:homepageURL="https://github.com/valeryzhu/zotero2notebookLM"
        em:iconURL="chrome://zotero2notebooklm/content/icons/icon.svg"
        em:multiprocessCompatible="true"
        em:bootstrap="true">
        <em:targetApplication>
            <Description>
                <em:id>zotero@chnm.gmu.edu</em:id>
                <em:minVersion>5.0</em:minVersion>
                <em:maxVersion>*</em:maxVersion>
            </Description>
        </em:targetApplication>
        <em:targetApplication>
            <Description>
                <em:id>zotero@zotero.org</em:id>
                <em:minVersion>6.999</em:minVersion>
                <em:maxVersion>9.*</em:maxVersion>
            </Description>
        </em:targetApplication>
        <em:targetApplication>
            <Description>
                <em:id>juris-m@juris-m.github.io</em:id>
                <em:minVersion>5.0</em:minVersion>
                <em:maxVersion>*</em:maxVersion>
            </Description>
        </em:targetApplication>
    </RDF:Description>
</RDF:RDF>
